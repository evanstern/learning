# Copy this file to `.env` and fill in your key, OR just export the variable
# in your shell before running. The code reads process.env.ANTHROPIC_API_KEY.
#
# NEVER commit a real key. NEVER hardcode it in source. This is the only place
# the demo expects a secret to come from.
ANTHROPIC_API_KEY=

# Optional: override the model used by the quarantined + planner LLMs.
# Defaults to a current Claude model if unset.
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional: port for the web UI (defaults to 3103).
# PORT=3103
